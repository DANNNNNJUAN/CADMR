# Copy this file to .env and edit values locally. Do not commit real secrets.

# OpenRouter / LLM extractor
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_TIMEOUT=60

# Demo/eval switches
CADMR_USE_LLM_EXTRACTOR=false
CADMR_USE_LLM_USABILITY_JUDGE=false
CADMR_USE_LLM_ANSWER_GENERATOR=false
CADMR_USE_LLM_VERIFIER=false

# Hard-case eval defaults
CADMR_EVAL_CASES_PATH=evals/hard_cases.json
CADMR_EVAL_RESULTS_PATH=evals/results_latest.json

# STALE eval defaults. CLI args still override these.
CADMR_STALE_DATASET=
CADMR_STALE_OUTPUT=evals/stale_answers_latest.json
CADMR_STALE_MAX_SAMPLES=
CADMR_LLM_CACHE_PATH=evals/openrouter_llm_cache.json
CADMR_HAYSTACK_EXTRACTOR_CACHE_PATH=evals/haystack_extractor_cache.json
CADMR_PREWARM_HAYSTACK_CACHE=false
CADMR_PARALLEL_DIMS=false
CADMR_MAX_JUDGE_MEMORIES=20
CADMR_MAX_JUDGE_CONSTRAINTS=5
CADMR_STALE_AWARE_RETRIEVAL=false
CADMR_RECENT_MEMORY_WINDOW=80
CADMR_CONSTRAINT_RANKER=lexical
CADMR_CONSTRAINT_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
CADMR_CONSTRAINT_EMBEDDING_CACHE_PATH=evals/constraint_embedding_cache.json
